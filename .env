# Trackay Backend Environment Variables
# Copy this file to .env and fill in your values

# Firebase Project
FIREBASE_PROJECT_ID=trackay-hospital-174c3

# Node API Key — ESP32-C6 nodes must send this in every request header
# Change this to any long random string before deploying
NODE_API_KEY=trackay-node-secret-key-change-this-2024

# Server port
PORT=3001

# Email alerts (optional — fill in to enable)
EMAIL_SMTP=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
EMAIL_TO=

# Tag offline timeout in minutes
TAG_OFFLINE_MINUTES=7
